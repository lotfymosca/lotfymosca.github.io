                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse sticky-top" id="navbarNavAltMarkup">
                    <div class="navbar-nav ul ms-1 nav-color">
                        <a class="nav-link" href="#">Home</a>
                        <a class="nav-link" href="#casual-shoes">Casual Shoes</a>
                        <a class="nav-link" href="#formal-shoes">Formal Shoes</a>
                        <a class="nav-link" href="#about">About Us</a>
                        <a class="nav-link" href="#contact">Contact Us</a>
                    </div>
                </div>
            </div>
        </nav>
        <!-- Navbar Section End  -->

        <!-- Carousel Section Start -->

        <div id="carouselExampleSlidesOnly" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-inner d-flex justify-content-between align-items-center">
                <div class="col-md-5">
                    <img src="images/Photos/Group 33092.png" class="d-block w-100" alt="...">
                </div>
                <div class="col-md-7">
                    <h1 class="price-color" style="font-family: 'Bebas Neue', cursive; font-weight: 300;">the page name 
                    <h1 style="color: #363958; font-family:'Bebas Neue', cursive;">the most product popular</h1>
                    <p class="text-dark">some text about the quality of our products</p>
                    <button class="link-button ms-auto"> Buy Now </button>
                </div>
            </div>
        </div>


        <!-- Carousel Section End  -->



        <!-- Header Section End  -->



