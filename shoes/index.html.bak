            <!-- Contact Section Start  -->

            <section id="contact">
                <div class="form-container">

                    <div class="container">

                        <div class="row py-3">
                            <div class="col text-black text-center m-auto">

                                <h2 class="font-weight-bold">Get In Touch</h2>
                                <p>Feel free to message us.</p>

                            </div>

                        </div>

                        <div class="row pb-4">
                            <div class="text-black m-auto">
                                <h4>Send a message</h4>
                            </div>
                        </div>

<form action="https://formspree.io/f/xwkjajey" method="POST">
 <label>
    Your email:
    <input type="email" name="email" class="email-box">
  </label>
  <label>
    Your message:
    <textarea name="message" id="msg-box"> </textarea>
  </label>
  <!-- your other form fields go here -->
